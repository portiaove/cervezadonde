{
  "name": "cervezadonde",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "cervezadonde.es — find the nearest open beer in Madrid (lata or barra), honouring opening hours and the municipal alcohol ordinance.",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "dotenv -e .env -- pnpm --filter @cervezadonde/db migrate up",
    "worker:ingest:sample": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:sample",
    "worker:ingest:madrid": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:madrid",
    "worker:ingest:barcelona": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:barcelona",
    "worker:ingest:diba": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:diba",
    "worker:crawl:hours": "dotenv -e .env -- pnpm --filter @cervezadonde/worker crawl:hours",
    "worker:ingest:osm:region": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:osm:region",
    "worker:ingest:osm:pbf": "dotenv -e .env -- pnpm --filter @cervezadonde/worker ingest:osm:pbf",
    "worker:diagnose:madrid": "dotenv -e .env -- pnpm --filter @cervezadonde/worker diagnose:madrid",
    "api:dev": "dotenv -e .env -- pnpm --filter @cervezadonde/api dev",
    "web:dev": "pnpm --filter @cervezadonde/web dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "dotenv-cli": "^7.4.2",
    "typescript": "^5.6.3"
  }
}
