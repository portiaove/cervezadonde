# Database
DATABASE_URL=postgres://minimarket:minimarket@localhost:5432/minimarket

# API
API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173

# Web (consumed by Vite at build time, must be prefixed VITE_)
VITE_API_URL=http://localhost:3001

# Ingestion sources — Censo de locales del Ayuntamiento de Madrid.
# Format: pipe-delimited UTF-8 CSV, coords in EPSG:25830 (ETRS89 UTM 30N).
# Schema: https://datos.madrid.es/.../200085-9-censo-locales.pdf
# Updated daily by the Ayuntamiento.
MADRID_CENSO_LOCALES_URL=https://datos.madrid.es/dataset/200085-0-censo-locales/resource/200085-1-censo-locales/download/200085-1-censo-locales.csv
MADRID_CENSO_ACTIVIDADES_URL=https://datos.madrid.es/dataset/200085-0-censo-locales/resource/200085-5-censo-locales/download/200085-5-censo-locales.csv

# Local cache for downloaded source files (relative to repo root).
MADRID_CACHE_DIR=./data/raw
