{
  "name": "@cervezadonde/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit",
    "migrate": "node-pg-migrate --migrations-dir ./migrations --migration-file-language sql",
    "migrate:up": "pnpm migrate up",
    "migrate:down": "pnpm migrate down"
  },
  "dependencies": {
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.13.1",
    "typescript": "^5.6.3"
  }
}
