# Copy to deploy/.env.prod on the server and fill in. NEVER commit .env.prod.

# Postgres (internal to the compose network)
# IMPORTANT: this password is embedded in a postgres:// connection URL, so it
# must be URL-safe. Generate with `openssl rand -hex 24` (hex only) — NOT
# `-base64`, whose / + = characters break URL parsing ("Invalid URL").
POSTGRES_USER=cervezadonde
POSTGRES_PASSWORD=change-me-run-openssl-rand-hex-24
POSTGRES_DB=cervezadonde

# Public origin (used for CORS; same-origin routing makes it mostly a formality)
WEB_ORIGIN=https://cervezadonde.es

# Domain Caddy should obtain a certificate for. Space-separate to add www.
SITE_ADDRESS=cervezadonde.es www.cervezadonde.es

# Host path to the uploaded web build (apps/web/dist) mounted into Caddy.
WEB_DIST_PATH=./web-dist
