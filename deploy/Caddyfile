# Caddy handles TLS automatically for the domain (Let's Encrypt).
# Same-origin routing: /api/* is stripped and proxied to the API; everything
# else serves the static web build with SPA fallback.
{$SITE_ADDRESS} {
	encode zstd gzip

	# Access log (JSON) for GoAccess analytics. Caddy self-rotates it; raw logs
	# stay short-lived while GoAccess persists long-term aggregates (docs/15).
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 336h
		}
		format json
	}

	handle_path /api/* {
		reverse_proxy api:3001
	}

	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
