# Caddy handles TLS automatically for the domain (Let's Encrypt).
# Same-origin routing: /api/* is stripped and proxied to the API; everything
# else serves the static web build with SPA fallback.
{$SITE_ADDRESS} {
	encode zstd gzip

	# Access log (JSON) for GoAccess analytics. Caddy self-rotates it; raw logs
	# stay short-lived while GoAccess persists long-term aggregates (docs/15).
	log {
		output file /var/log/caddy/access.log {
			roll_size 10MiB
			roll_keep 30
			roll_keep_for 1440h
		}
		format json
	}

	# Optional host-only routes (e.g. the password-protected /analytics). Kept out
	# of git so secrets stay off the public repo; a missing dir is a harmless
	# no-op, so this can never take the site down. See docs/15 §4.
	import /etc/caddy/conf.d/*.caddy

	handle_path /api/* {
		# Time-sensitive answers (open-now verdicts) — never cache.
		header Cache-Control "no-store"
		reverse_proxy api:3001
	}

	handle {
		root * /srv/web
		try_files {path} /index.html

		# Vite assets are content-hashed (index-Bx50e8OR.js) → immutable:
		# cache for a year, never re-downloaded until the hash changes.
		@hashed path /assets/*
		header @hashed Cache-Control "public, max-age=31536000, immutable"

		# index.html (and favicon etc.) must REVALIDATE on every navigation —
		# the ETag makes that a cheap 304 — so a deploy is picked up on the
		# next page load. Without this, browsers heuristically cache the old
		# index.html, which points at the old bundle → stale tabs after deploys.
		@rest not path /assets/*
		header @rest Cache-Control "no-cache"

		file_server
	}
}
